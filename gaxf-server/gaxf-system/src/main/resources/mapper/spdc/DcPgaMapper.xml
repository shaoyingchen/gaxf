<mapper namespace="com.gaxf.spdc.mapper.DcPgaMapper">

    <resultMap type="DcPga" id="DcPgaResult">
        <result property="id"    column="id"    />
        <result property="dxjgId"    column="dxjg_id"    />
        <result property="problemDepart"    column="problem_depart"    />
        <result property="dealtype"    column="dealtype"    />
        <result property="wtxz"    column="wtxz"    />
        <result property="adjust"    column="adjust"    />
        <result property="dealPropose"    column="deal_propose"    />
        <result property="typeLevelone"    column="type_levelone"    />
        <result property="typeLeveltwo"    column="type_leveltwo"    />
        <result property="pic1"    column="pic1"    />
        <result property="fujian"    column="fujian"    />
        <result property="camareCode"    column="camare_code"    />
        <result property="problemMsg"    column="problem_msg"    />
        <result property="findtime"    column="findtime"    />
        <result property="countyname"    column="countyname"    />
        <result property="policename"    column="policename"    />
        <result property="danweiallname"    column="danweiallname"    />
        <result property="jz"    column="jz"    />
