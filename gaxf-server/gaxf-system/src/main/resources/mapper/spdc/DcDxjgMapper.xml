    <delete id="deleteDcDxjgById" parameterType="Integer">
        update dc_dxjg set deleted = b'1' where id = #{id}
    </delete>

    <delete id="deleteDcDxjgByIds" parameterType="String">
        update dc_dxjg set deleted = b'1' where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
