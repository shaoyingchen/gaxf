        <result property="deptName"    column="dept_name"    />
        <result property="cameraName"    column="camera_name"    />
        <result property="todayCount"    column="todayCount"    />
        <result property="highCount"    column="highCount"    />
        <result property="pendingCount"    column="pendingCount"    />
        <result property="resolvedCount"    column="resolvedCount"    />
    </resultMap>

    <sql id="selectDcDxjgVo">
        select d.id, d.orgid, d.warningtype, d.policename, d.countyname, d.orgtableid, d.time, d.state,
               d.msgtitle, d.pic1, d.pic2, d.type, d.accept_userid, d.sendsate, d.depart_id, d.camera_id,
               d.creator, d.create_time, d.updater, d.update_time, d.deleted, d.event_code, d.result, d.deal,
               d.zone_type, d.room_type, d.county, d.main_type, d.is_resolved,
               sd.dept_name as dept_name,
               dc.name as camera_name
        from dc_dxjg d
        left join sys_dept sd on d.depart_id = sd.dept_id
        left join dc_cameratable dc on d.camera_id = dc.id
    </sql>

    <select id="selectDcDxjgList" parameterType="DcDxjg" resultMap="DcDxjgResult">
        <include refid="selectDcDxjgVo"/>
        <where>
            <if test="warningtype != null and warningtype != ''"> and d.warningtype = #{warningtype}</if>
            <if test="type != null and type != ''"> and d.type = #{type}</if>
            <if test="mainType != null and mainType != ''"> and d.main_type = #{mainType}</if>
            <if test="deal != null and deal != ''"> and d.deal = #{deal}</if>
            <if test="isResolved != null"> and d.is_resolved = #{isResolved}</if>
            <if test="departId != null"> and d.depart_id = #{departId}</if>
            <if test="cameraId != null"> and d.camera_id = #{cameraId}</if>
            <if test="policename != null and policename != ''"> and d.policename like concat('%', #{policename}, '%')</if>
            <if test="countyname != null and countyname != ''"> and d.countyname like concat('%', #{countyname}, '%')</if>
            <if test="zoneType != null and zoneType != ''"> and d.zone_type = #{zoneType}</if>
            <if test="roomType != null and roomType != ''"> and d.room_type = #{roomType}</if>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(d.time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(d.time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
            <!-- 数据范围过滤：查询当前部门及下级部门的预警 -->
            <if test="userDeptId != null and userDeptId != 0">
                and (d.depart_id = #{userDeptId} or d.depart_id in (
                    select dept_id from sys_dept where del_flag = '0' and find_in_set(#{userDeptId}, ancestors)
                ))
            </if>
            and d.deleted = b'0'
        </where>
        order by d.time desc
    </select>

    <select id="selectDcDxjgById" parameterType="Integer" resultMap="DcDxjgResult">
        <include refid="selectDcDxjgVo"/>
        where d.id = #{id}
    </select>

    <select id="selectDcDxjgStatistics" parameterType="Long" resultMap="DcDxjgResult">
        select
            count(*) as todayCount,
            sum(case when d.is_resolved = 1 and d.deal = '02' and d.deal != '01' then 1 else 0 end) as verifyCount,
            sum(case when d.deal = '03' then 1 else 0 end) as pendingCount,
            sum(case when d.deal = '02' then 1 else 0 end) as resolvedCount
        from dc_dxjg d
        <where>
            <if test="userDeptId != null and userDeptId != 0">
                and (d.depart_id = #{userDeptId} or d.depart_id in (
                    select dept_id from sys_dept where del_flag = '0' and find_in_set(#{userDeptId}, ancestors)
                ))
            </if>
            and d.deleted = b'0'
        </where>
    </select>

