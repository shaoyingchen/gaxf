    <delete id="deleteDcCameraByPointId" parameterType="Integer">
        update dc_cameratable set deleted = b'1' where id = #{pointId}
    </delete>

    <delete id="deleteDcCameraByPointIds" parameterType="String">
        update dc_cameratable set deleted = b'1' where id in
        <foreach item="pointId" collection="array" open="(" separator="," close=")">
            #{pointId}
        </foreach>
    </delete>
