    </resultMap>

    <sql id="selectDcCameraVo">
        select id, gbcode, dept_id, shorttext, name, roomkind, zonetype_id, zonetype, upalarm, ip, port, dvrname, dvrpassword, dvrinput, dvrkind, county, city, jz, state, connstate, person_num, code, gbstate, parentcode, detect, must_acc, detect_tag, c_count, duty_user, duty_tel, creator, create_time, updater, update_time, deleted, enable from dc_cameratable
    </sql>

    <select id="selectDcCameraList" parameterType="DcCamera" resultMap="DcCameraResult">
        <include refid="selectDcCameraVo"/>
        <where>
            <if test="gbCode != null  and gbCode != ''"> and gbcode = #{gbCode}</if>
            <if test="deptId != null "> and dept_id = #{deptId}</if>
            <if test="deptName != null  and deptName != ''"> and shorttext like concat('%', #{deptName}, '%')</if>
            <if test="pointName != null  and pointName != ''"> and name like concat('%', #{pointName}, '%')</if>
            <if test="roomKind != null  and roomKind != ''"> and roomkind = #{roomKind}</if>
            <if test="zoneType != null  and zoneType != ''"> and zonetype = #{zoneType}</if>
            <if test="upAlarm != null "> and upalarm = #{upAlarm}</if>
            <if test="pointStatus != null "> and state = #{pointStatus}</if>
            <if test="cameraType != null "> and dvrkind = #{cameraType}</if>
            <if test="ipAddress != null  and ipAddress != ''"> and ip = #{ipAddress}</if>
            <if test="port != null  and port != ''"> and port = #{port}</if>
            <if test="username != null  and username != ''"> and dvrname like concat('%', #{username}, '%')</if>
            <if test="password != null  and password != ''"> and dvrpassword = #{password}</if>
            <if test="channelNo != null "> and dvrinput = #{channelNo}</if>
            <if test="code != null  and code != ''"> and code = #{code}</if>
            <if test="detect != null "> and detect = #{detect}</if>
            <if test="dutyUser != null  and dutyUser != ''"> and duty_user like concat('%', #{dutyUser}, '%')</if>
            <if test="enable != null "> and enable = #{enable}</if>
            <!-- 数据范围过滤：查询当前部门及下级部门的点位 -->
            <if test="userDeptId != null and userDeptId != 0">
                and (dept_id = #{userDeptId} or dept_id in (select dept_id from sys_dept where del_flag = '0' and find_in_set(#{userDeptId}, ancestors)))
            </if>
            and deleted = b'0'
        </where>
    </select>

    <select id="selectDcCameraByPointId" parameterType="Integer" resultMap="DcCameraResult">
        <include refid="selectDcCameraVo"/>
        where id = #{pointId}
    </select>

    <insert id="insertDcCamera" parameterType="DcCamera" useGeneratedKeys="true" keyProperty="pointId">
        insert into dc_cameratable
        <trim prefix="(" suffix=")" suffixOverrides=",">
