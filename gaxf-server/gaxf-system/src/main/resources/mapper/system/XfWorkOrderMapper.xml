    <sql id="selectXfWorkOrderVo">
        select id, xf_case_no, title, source_type, content, petitioner_name, petitioner_idcard,
               petitioner_phone, petitioner_address, xf_content, register_time, deadline,
               xf_case_status, xf_form, xf_date, problem_location, abnormal_dynamic,
               problem_date, petitioner_count, xf_demand, business_category, register_unit,
               archive_no, transfer_dest, handle_method, specific_handle_unit,
               completion_status, responsible_dept, completion_time, xf_item_no,
               police_type_name, xf_purpose,
               status, overdue_count, is_locked, is_top,
               create_dept_id, del_flag, create_by, create_time, update_by, update_time, remark
        from xf_work_order
    </sql>

    <select id="selectXfWorkOrderById" parameterType="Long" resultMap="XfWorkOrderResult">
        <include refid="selectXfWorkOrderVo"/>
        where id = #{id} and del_flag = '0'
    </select>

    <select id="selectXfWorkOrderList" parameterType="XfWorkOrder" resultMap="XfWorkOrderResult">
        <include refid="selectXfWorkOrderVo"/>
        <where>
            del_flag = '0'
            <if test="xfCaseNo != null and xfCaseNo != ''">
                AND xf_case_no like concat('%', #{xfCaseNo}, '%')
            </if>
            <if test="title != null and title != ''">
                AND title like concat('%', #{title}, '%')
            </if>
            <if test="sourceType != null and sourceType != ''">
                AND source_type = #{sourceType}
            </if>
            <if test="petitionerName != null and petitionerName != ''">
                AND petitioner_name like concat('%', #{petitionerName}, '%')
            </if>
            <if test="xfForm != null and xfForm != ''">
                AND xf_form = #{xfForm}
            </if>
            <if test="businessCategory != null and businessCategory != ''">
                AND business_category = #{businessCategory}
            </if>
            <if test="xfCaseStatus != null and xfCaseStatus != ''">
                AND xf_case_status = #{xfCaseStatus}
            </if>
            <if test="registerUnit != null and registerUnit != ''">
                AND register_unit like concat('%', #{registerUnit}, '%')
            </if>
            <if test="policeTypeName != null and policeTypeName != ''">
                AND police_type_name like concat('%', #{policeTypeName}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="isLocked != null and isLocked != ''">
                AND is_locked = #{isLocked}
            </if>
            <if test="isTop != null and isTop != ''">
                AND is_top = #{isTop}
            </if>
            <if test="createDeptId != null">
                AND create_dept_id = #{createDeptId}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(register_time,'%Y%m%d') &gt;= date_format(#{params.beginTime},'%Y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(register_time,'%Y%m%d') &lt;= date_format(#{params.endTime},'%Y%m%d')
            </if>
        </where>
        order by is_top desc, create_time desc
    </select>

    <select id="selectMyTodoList" parameterType="XfWorkOrder" resultMap="XfWorkOrderResult">
        select wo.id, wo.xf_case_no, wo.title, wo.source_type, wo.content, wo.petitioner_name,
               wo.petitioner_idcard, wo.petitioner_phone, wo.petitioner_address, wo.xf_content,
               wo.register_time, wo.deadline, wo.xf_case_status, wo.xf_form, wo.xf_date,
               wo.problem_location, wo.abnormal_dynamic, wo.problem_date, wo.petitioner_count,
               wo.xf_demand, wo.business_category, wo.register_unit, wo.archive_no,
               wo.transfer_dest, wo.handle_method, wo.specific_handle_unit, wo.completion_status,
               wo.responsible_dept, wo.completion_time, wo.xf_item_no, wo.police_type_name,
               wo.xf_purpose, wo.status, wo.overdue_count, wo.is_locked, wo.is_top,
               wo.create_dept_id, wo.del_flag, wo.create_by, wo.create_time, wo.update_by,
               wo.update_time, wo.remark,
               ar.id as assign_id
        from xf_work_order wo
        left join xf_assign_record ar on wo.id = ar.order_id
        <where>
            wo.del_flag = '0'
            <if test="params.assignDeptId != null">
                AND ar.assign_dept_id = #{params.assignDeptId}
            </if>
            <if test="params.assignStatus != null and params.assignStatus != ''">
                AND ar.status = #{params.assignStatus}
            </if>
            <if test="status != null and status != ''">
                AND wo.status = #{status}
            </if>
        </where>
        order by wo.is_top desc, wo.create_time desc
    </select>

    <select id="selectStatistics" resultType="java.util.Map">
        select status, count(*) as count from xf_work_order where del_flag = '0' group by status
    </select>

    <select id="selectMyTodoStatistics" resultType="java.util.Map">
        select ar.status, count(*) as count
        from xf_assign_record ar
        left join xf_work_order wo on ar.order_id = wo.id
        where wo.del_flag = '0' and ar.assign_dept_id = #{deptId}
        group by ar.status
    </select>

    <select id="selectOverdueList" resultMap="XfWorkOrderResult">
        <include refid="selectXfWorkOrderVo"/>
        where del_flag = '0' and status in ('0', '1') and deadline &lt; sysdate()
    </select>

